---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import BlogPostCard from "@components/BlogPostCard.astro";
import { getHomepagePosts, displayTitle, displayDescription, formatDate } from "@lib/posts";
import { SITE } from "@lib/site";

const posts = await getHomepagePosts();
const [first, second, third, ...rest] = posts;
---
<!-- Layout: minimaal, editoraal — nummering + geen grote hero -->
<BaseLayout
  title={`Theorie blog — CBR voorbereiding | ${SITE.name}`}
  description="Praktische artikelen voor je CBR theorie-examen. Gevaarherkenning, verkeerskennis en verkeersinzicht."
>
  <section class="border-b border-slate-200 bg-white py-10">
    <Container>
      <div class="flex items-end justify-between">
        <div>
          <span class="text-xs font-bold uppercase tracking-widest text-brand-600">Autotheorie.net</span>
          <h1 class="mt-1 text-4xl font-extrabold tracking-tight text-slate-900">Theorieblog</h1>
        </div>
        <span class="text-sm text-slate-400">{posts.length} artikelen</span>
      </div>
    </Container>
  </section>

  <Container class="py-(--spacing-section)">
    {/* Top 3 als grote kaarten met nummer */}
    {[first, second, third].filter(Boolean).length > 0 && (
      <div class="mb-12 grid gap-6 md:grid-cols-3">
        {[first, second, third].filter(Boolean).map((p, i) => p && (
          <a href={`/${p.id}/`}
             class="group relative flex flex-col overflow-hidden rounded-2xl bg-brand-50 border border-brand-100 p-6 transition hover:bg-brand-100 hover:border-brand-300">
            <span class="text-5xl font-extrabold text-brand-200 leading-none">{String(i + 1).padStart(2, '0')}</span>
            <time class="mt-3 text-xs font-semibold text-brand-700">{formatDate(p.data.date)}</time>
            <h2 class="mt-1 font-bold leading-snug text-slate-900 group-hover:text-brand-700 line-clamp-3">{displayTitle(p)}</h2>
            <span class="mt-auto pt-4 text-xs font-bold text-brand-700">Lees →</span>
          </a>
        ))}
      </div>
    )}

    {/* Overige artikelen als kaarten */}
    {rest.length > 0 && (
      <>
        <div class="mb-6 flex items-center gap-4">
          <h2 class="text-lg font-bold text-slate-900">Meer artikelen</h2>
          <div class="h-px flex-1 bg-slate-200"></div>
        </div>
        <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
          {rest.map((p) => <BlogPostCard post={p} />)}
        </div>
      </>
    )}
  </Container>
</BaseLayout>
