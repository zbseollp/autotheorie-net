---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";

const categories = [
  { title: "Gevaarborden", desc: "Driehoekige borden die waarschuwen voor gevaren op de weg.", count: "30+" },
  { title: "Verbodsborden", desc: "Ronde borden met rode rand die verbieden of verplichten.", count: "25+" },
  { title: "Gebodsborden", desc: "Ronde blauwe borden die verplicht gedrag voorschrijven.", count: "20+" },
  { title: "Informatieborden", desc: "Rechthoekige borden die informatie geven over de weg.", count: "40+" },
  { title: "Aanwijzingsborden", desc: "Borden die specifieke aanwijzingen geven voor weggebruikers.", count: "15+" },
  { title: "Bebakening", desc: "Palen, bakens en markeringen langs de weg.", count: "10+" },
];
---
<BaseLayout
  title="Alle Verkeersborden Leren — Compleet Overzicht | Autotheorie.net"
  description="Leer alle Nederlandse verkeersborden voor het CBR theorie-examen. Compleet overzicht van gevaar-, verbods-, gebods- en informatieborden."
>
  <section class="bg-[linear-gradient(180deg,var(--color-brand-50)_0%,#fff_60%)]">
    <Container class="py-(--spacing-section)">
      <h1 class="text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl">
        Verkeersborden leren
      </h1>
      <p class="mt-4 max-w-2xl text-lg text-slate-600">
        Ken jij alle Nederlandse verkeersborden? Voor het CBR theorie-examen moet je de
        betekenis van tientallen borden uit je hoofd kennen. Oefen hier per categorie.
      </p>
    </Container>
  </section>

  <Container class="py-(--spacing-section)">
    <h2 class="text-2xl font-extrabold text-slate-900 mb-6">Categorieën verkeersborden</h2>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {categories.map((cat) => (
        <div class="rounded-2xl border border-slate-200 bg-white p-6">
          <div class="flex items-start justify-between">
            <h3 class="text-lg font-bold text-slate-900">{cat.title}</h3>
            <span class="text-xs font-semibold text-brand-700 bg-brand-50 rounded-full px-2 py-0.5">{cat.count}</span>
          </div>
          <p class="mt-2 text-sm text-slate-600">{cat.desc}</p>
        </div>
      ))}
    </div>

    <div class="mt-12 rounded-2xl bg-brand-700 p-8 text-center">
      <h2 class="text-2xl font-bold text-white">Oefen met verkeersborden</h2>
      <p class="mt-2 text-brand-100">Test je kennis met onze verkeersborden quiz.</p>
      <a href="/auto-theorie/" class="mt-5 inline-flex items-center rounded-xl bg-white px-6 py-3 font-bold text-brand-700 hover:bg-brand-50 transition">
        Start de oefenquiz →
      </a>
    </div>

    <div class="mt-12 article-prose">
      <h2>Waarom verkeersborden leren voor het CBR examen?</h2>
      <p>Kennis van verkeersborden is een essentieel onderdeel van het theorie-examen.
      Zowel bij verkeerskennis als bij verkeersinzicht komen vragen voor waarbij je een
      verkeersbord moet herkennen en de juiste actie moet kiezen.</p>
      <p>Reken op minimaal 5 vragen over verkeersborden in je examen. Door alle borden goed
      te kennen verhoog je je score aanzienlijk.</p>
      <h3>Meest voorkomende borden in het CBR examen</h3>
      <ul>
        <li>Voorrangsbord (gele ruit) en het kruispunt-voorrangsbord</li>
        <li>Stopp en geef voorrang (driehoek met punt omlaag)</li>
        <li>Snelheidslimieten (50, 80, 100, 120 km/h)</li>
        <li>Verboden in te rijden en eenrichtingsverkeer</li>
        <li>Fietspad, voetpad en woonerf</li>
      </ul>
    </div>
  </Container>
</BaseLayout>
