---
import BaseLayout from "@layouts/BaseLayout.astro";
import Container from "@components/Container.astro";
import BlogPostCard from "@components/BlogPostCard.astro";
import { getRecentPosts } from "@lib/posts";
import { SITE } from "@lib/site";

const recent = await getRecentPosts(3);

const examParts = [
  {
    num: "25",
    unit: "vragen",
    title: "Gevaarherkenning",
    desc: "Herken gevaarlijke situaties in het verkeer. Je hebt 8 seconden per vraag.",
    color: "bg-yellow-50 border-yellow-200",
    badge: "bg-yellow-400 text-yellow-900",
    href: "/gevaarherkenning/",
  },
  {
    num: "12",
    unit: "vragen",
    title: "Verkeerskennis",
    desc: "Verkeersregels, verkeersborden en situaties. Je hebt 7 minuten de tijd.",
    color: "bg-brand-50 border-brand-200",
    badge: "bg-brand-600 text-white",
    href: "/verkeerskennis/",
  },
  {
    num: "28",
    unit: "vragen",
    title: "Verkeersinzicht",
    desc: "Inzicht in complexe verkeerssituaties. Je hebt 15 minuten de tijd.",
    color: "bg-slate-50 border-slate-200",
    badge: "bg-slate-700 text-white",
    href: "/verkeersinzicht/",
  },
];

const stats = [
  { value: "161.835+", label: "Toetsen gemaakt" },
  { value: "50%", label: "Slagingspercentage CBR" },
  { value: "€33", label: "Kosten theorie-examen" },
  { value: "100%", label: "Gratis oefenen" },
];

const tips = [
  "Slechts 50% van de kandidaten slaagt in één keer voor het theorie-examen.",
  "Je mag maximaal 10 fouten maken om te slagen (bij 50 vragen).",
  "Oefenen met officiële CBR-vragen verhoogt je slagingskans aanzienlijk.",
];

const jsonld = {
  "@context": "https://schema.org",
  "@graph": [
    { "@type": "Organization", "@id": `${SITE.url}/#org`, name: SITE.name, url: SITE.url },
    { "@type": "WebSite", "@id": `${SITE.url}/#website`, url: SITE.url, name: SITE.name, publisher: { "@id": `${SITE.url}/#org` }, inLanguage: "nl-NL" },
  ],
};
---
<BaseLayout
  title="Autotheorie Leren & Oefenen — Gratis CBR Voorbereiding 2026"
  description={SITE.description}
>
  <script type="application/ld+json" set:html={JSON.stringify(jsonld)} is:inline />

  <!-- Hero: licht blauw, split layout met stats-kaart -->
  <section class="relative -mt-16 pt-16 md:-mt-20 md:pt-20 bg-[linear-gradient(135deg,var(--color-brand-50)_0%,#fff_60%)] overflow-hidden">
    <Container class="grid items-center gap-12 py-(--spacing-section) lg:grid-cols-2">
      <div>
        <span class="inline-flex items-center gap-1.5 rounded-full bg-brand-100 px-3 py-1 text-sm font-semibold text-brand-800">
          ✓ Gratis · ✓ CBR 2026 · ✓ Auto & Motor
        </span>
        <h1 class="mt-5 text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl lg:text-6xl">
          De beste<br />
          <span class="text-brand-600">autotheorie</span><br />
          voorbereiding
        </h1>
        <p class="mt-5 max-w-lg text-lg text-slate-600">
          Oefen gratis voor het CBR theorie-examen. Gevaarherkenning, verkeerskennis
          en verkeersinzicht — alles op één plek.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/auto-theorie/"
             class="inline-flex items-center rounded-xl bg-brand-600 px-7 py-3.5 text-base font-bold text-white shadow-md hover:bg-brand-700 transition">
            Start GRATIS oefening →
          </a>
          <a href="/blog/"
             class="inline-flex items-center rounded-xl border border-slate-300 px-7 py-3.5 text-base font-semibold text-slate-700 hover:bg-slate-50 transition">
            Theorie tips
          </a>
        </div>
      </div>

      <!-- Stats kaart -->
      <div class="grid grid-cols-2 gap-4">
        {stats.map((s) => (
          <div class="rounded-2xl border border-brand-100 bg-white p-6 shadow-sm text-center">
            <div class="text-3xl font-extrabold text-brand-700">{s.value}</div>
            <div class="mt-1 text-sm text-slate-500">{s.label}</div>
          </div>
        ))}
      </div>
    </Container>
  </section>

  <!-- Examen opbouw -->
  <section class="bg-white border-y border-slate-100">
    <Container class="py-(--spacing-section)">
      <div class="text-center mb-10">
        <h2 class="text-3xl font-extrabold tracking-tight text-slate-900">Zo is het CBR examen opgebouwd</h2>
        <p class="mt-3 text-slate-600 max-w-xl mx-auto">Het theorie-examen bestaat uit 3 onderdelen. Oefen elk onderdeel apart voor het beste resultaat.</p>
      </div>
      <div class="grid gap-5 md:grid-cols-3">
        {examParts.map((p) => (
          <a href={p.href}
             class={`group flex flex-col rounded-2xl border p-6 transition hover:-translate-y-0.5 hover:shadow-md ${p.color}`}>
            <div class={`inline-flex items-baseline gap-1 rounded-xl px-3 py-1 text-sm font-bold w-fit ${p.badge}`}>
              {p.num} {p.unit}
            </div>
            <h3 class="mt-4 text-xl font-bold text-slate-900 group-hover:text-brand-700">{p.title}</h3>
            <p class="mt-2 flex-1 text-sm text-slate-600 leading-relaxed">{p.desc}</p>
            <span class="mt-4 text-sm font-semibold text-brand-700">Ga oefenen →</span>
          </a>
        ))}
      </div>
    </Container>
  </section>

  <!-- Wist je dat -->
  <section class="bg-brand-700">
    <Container class="py-12">
      <h2 class="text-xl font-bold text-white mb-6 text-center">Wist je dat...</h2>
      <div class="grid gap-4 sm:grid-cols-3">
        {tips.map((tip) => (
          <div class="rounded-xl bg-white/10 backdrop-blur px-5 py-4 text-sm text-brand-100 leading-relaxed">
            💡 {tip}
          </div>
        ))}
      </div>
      <div class="mt-8 text-center">
        <a href="/auto-theorie/"
           class="inline-flex items-center rounded-xl bg-white px-8 py-3.5 font-bold text-brand-700 hover:bg-brand-50 transition">
          Begin nu gratis te oefenen
        </a>
      </div>
    </Container>
  </section>

  <!-- Laatste blog posts -->
  {recent.length > 0 && (
    <section class="bg-slate-50">
      <Container class="py-(--spacing-section)">
        <div class="flex items-end justify-between mb-8">
          <h2 class="text-2xl font-extrabold tracking-tight text-slate-900">Autotheorie tips & nieuws</h2>
          <a href="/blog/" class="text-sm font-semibold text-brand-700 hover:underline">Alle artikelen →</a>
        </div>
        <div class="grid gap-6 sm:grid-cols-3">
          {recent.map((p, i) => <BlogPostCard post={p} eager={i === 0} />)}
        </div>
      </Container>
    </section>
  )}
</BaseLayout>
